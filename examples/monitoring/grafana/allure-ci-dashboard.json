{
  "dashboard": {
    "annotations": {
      "list": []
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "panels": [
      {
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "blue"
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 0,
          "y": 0
        },
        "id": 1,
        "options": {
          "colorMode": "background",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "expr": "sum(allure_tests{project=~\"$project\", status=\"total\"})",
            "instant": true,
            "refId": "A"
          }
        ],
        "title": "Total tests",
        "type": "stat"
      },
      {
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "color": {
              "fixedColor": "green",
              "mode": "fixed"
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 4,
          "y": 0
        },
        "id": 2,
        "options": {
          "colorMode": "background",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "expr": "sum(allure_tests{project=~\"$project\", status=\"passed\"})",
            "instant": true,
            "refId": "A"
          }
        ],
        "title": "Passed",
        "type": "stat"
      },
      {
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green"
                },
                {
                  "color": "red",
                  "value": 1
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 8,
          "y": 0
        },
        "id": 3,
        "options": {
          "colorMode": "background",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "expr": "sum(allure_tests{project=~\"$project\", status=~\"failed|broken\"})",
            "instant": true,
            "refId": "A"
          }
        ],
        "title": "Failed / Broken",
        "type": "stat"
      },
      {
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "max": 100,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red"
                },
                {
                  "color": "yellow",
                  "value": 80
                },
                {
                  "color": "green",
                  "value": 95
                }
              ]
            },
            "unit": "percent"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 12,
          "y": 0
        },
        "id": 4,
        "options": {
          "colorMode": "background",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "expr": "100 * sum(allure_tests{project=~\"$project\", status=\"passed\"}) / sum(allure_tests{project=~\"$project\", status=\"total\"})",
            "instant": true,
            "refId": "A"
          }
        ],
        "title": "Pass rate %",
        "type": "stat"
      },
      {
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "color": {
              "fixedColor": "orange",
              "mode": "fixed"
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 16,
          "y": 0
        },
        "id": 5,
        "options": {
          "colorMode": "value",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "expr": "sum(allure_tests{project=~\"$project\", status=\"skipped\"})",
            "instant": true,
            "refId": "A"
          }
        ],
        "title": "Skipped",
        "type": "stat"
      },
      {
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "mappings": [
              {
                "options": {
                  "0": {
                    "color": "red",
                    "text": "DOWN"
                  },
                  "1": {
                    "color": "green",
                    "text": "UP"
                  }
                },
                "type": "value"
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red"
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 20,
          "y": 0
        },
        "id": 6,
        "options": {
          "colorMode": "background",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "expr": "allure_exporter_up",
            "instant": true,
            "refId": "A"
          }
        ],
        "title": "Exporter up",
        "type": "stat"
      },
      {
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 10,
              "lineWidth": 2,
              "showPoints": "auto"
            }
          }
        },
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 0,
          "y": 4
        },
        "id": 7,
        "options": {
          "legend": {
            "placement": "bottom",
            "showLegend": true
          },
          "tooltip": {
            "mode": "multi"
          }
        },
        "targets": [
          {
            "expr": "allure_tests{project=~\"$project\", status=\"total\"}",
            "legendFormat": "{{project}} total",
            "refId": "A"
          },
          {
            "expr": "allure_tests{project=~\"$project\", status=\"passed\"}",
            "legendFormat": "{{project}} passed",
            "refId": "B"
          },
          {
            "expr": "allure_tests{project=~\"$project\", status=~\"failed|broken\"}",
            "legendFormat": "{{project}} failed/broken",
            "refId": "C"
          }
        ],
        "title": "Tests count per project (trend)",
        "type": "timeseries"
      },
      {
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green"
                },
                {
                  "color": "yellow",
                  "value": 60000
                },
                {
                  "color": "red",
                  "value": 300000
                }
              ]
            },
            "unit": "ms"
          }
        },
        "gridPos": {
          "h": 9,
          "w": 6,
          "x": 12,
          "y": 4
        },
        "id": 8,
        "options": {
          "displayMode": "gradient",
          "orientation": "horizontal",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "expr": "allure_last_run_duration_ms{project=~\"$project\"}",
            "instant": true,
            "legendFormat": "{{project}}",
            "refId": "A"
          }
        ],
        "title": "Last run duration per project",
        "type": "bargauge"
      },
      {
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green"
                },
                {
                  "color": "yellow",
                  "value": 24
                },
                {
                  "color": "red",
                  "value": 168
                }
              ]
            },
            "unit": "h"
          }
        },
        "gridPos": {
          "h": 9,
          "w": 6,
          "x": 18,
          "y": 4
        },
        "id": 9,
        "options": {
          "colorMode": "value",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "textMode": "value_and_name"
        },
        "targets": [
          {
            "expr": "(time() - allure_last_run_timestamp{project=~\"$project\"}/1000) / 3600",
            "instant": true,
            "legendFormat": "{{project}}",
            "refId": "A"
          }
        ],
        "title": "Last run age (часов назад)",
        "type": "stat"
      }
    ],
    "refresh": "30s",
    "schemaVersion": 39,
    "tags": [
      "allure",
      "ci",
      "tests"
    ],
    "templating": {
      "list": [
        {
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "datasource": "Prometheus",
          "includeAll": true,
          "multi": true,
          "name": "project",
          "query": "label_values(allure_tests, project)",
          "refresh": 1,
          "sort": 1,
          "type": "query"
        }
      ]
    },
    "time": {
      "from": "now-7d",
      "to": "now"
    },
    "timezone": "browser",
    "title": "Allure CI — тесты и тренды",
    "uid": null
  },
  "overwrite": true
}